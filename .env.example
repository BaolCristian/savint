# Database PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/savint

# Google OAuth (https://console.cloud.google.com/)
# Redirect URI in Google Console: https://tuodominio.it/savint/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth — genera il secret con: openssl rand -base64 32
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# In produzione: NON usare NEXTAUTH_URL, usare AUTH_URL
# AUTH_URL=https://tuodominio.it/savint
AUTH_TRUST_HOST=true

# In sviluppo locale (decommentare):
# NEXTAUTH_URL=http://localhost:3000

# Demo mode (abilita login con email senza password, per test/demo)
# DEMO_MODE=true
# NEXT_PUBLIC_DEMO_MODE=true

# Pixabay API (opzionale, per ricerca immagini nell'editor)
# PIXABAY_API_KEY=your-pixabay-api-key

# Porta del server (default: 3000)
# PORT=3001

# Timeout sessioni in ore (default: 2)
# Le sessioni LOBBY e IN_PROGRESS vengono chiuse automaticamente dopo questo tempo
# SESSION_TIMEOUT_HOURS=2

# GDPR: conservazione sessioni in giorni (default: 365)
# Le sessioni terminate vengono eliminate automaticamente dopo questo periodo
# SESSION_RETENTION_DAYS=365

# ── SAVINT Hub mode ────────────────────────────────────────────────────────
# Set to "hub" to run this instance as the central savint.it hub.
# Default (or any other value) keeps this instance in installation mode.
# SAVINT_MODE=installation

# Public base URL for hub-generated links (e.g. email verification).
# Required when SAVINT_MODE=hub.
# HUB_BASE_URL=https://savint.it

# Hub catalog URL the installation talks to (only used when SAVINT_MODE=installation).
# SAVINT_HUB_URL=https://savint.it

# Email sender for hub transactional emails. Required when SAVINT_MODE=hub.
# HUB_EMAIL_FROM=noreply@savint.it

# SMTP configuration for nodemailer. Required when SAVINT_MODE=hub.
# HUB_SMTP_HOST=smtp.mailgun.org
# HUB_SMTP_PORT=587
# HUB_SMTP_SECURE=false
# HUB_SMTP_USER=postmaster@mg.savint.it
# HUB_SMTP_PASS=<secret>

# Salt for one-way IP hashing (PracticeRun.ipHash, HubReport.reporterIpHash).
# Required when SAVINT_MODE=hub. Generate with: openssl rand -base64 32
# HUB_IP_HASH_SECRET=generate-with-openssl-rand-base64-32

# Hub integration (installation mode)
# SAVINT_HUB_URL=https://savint.it
# HUB_OAUTH_CLIENT_ID=
# HUB_OAUTH_CLIENT_SECRET=
# Hub limits (hub mode)
# HUB_MAX_QUIZ_SIZE_MB=50
# HUB_PUBLIC_QUIZZES_PER_ACCOUNT_MAX=200
